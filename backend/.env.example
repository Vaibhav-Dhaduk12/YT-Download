# Application
APP_NAME=MediaDownloader
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# CORS
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# Redis (optional)
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_HOUR=100

# Download
TEMP_DIR=./temp
MAX_FILE_SIZE_MB=500
DOWNLOAD_TIMEOUT=300
# Optional explicit binary locations (recommended on Windows when PATH differs by shell/process)
FFMPEG_PATH=
FFPROBE_PATH=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
